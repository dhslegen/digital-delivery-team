{
  "name": "digital-delivery-team",
  "version": "0.7.2",
  "description": "一人一队：全栈工程师 + AI 数字员工交付插件。8 个子代理 + 19 个命令 + 11 个 skill（含 backend/frontend-development）+ 8 类 hook + 5 套技术栈预设 + 4 套 AI-native UI 通道 + 6-phase 开发范式（EXPLORE/PLAN/APPROVE/IMPLEMENT/VERIFY/SUMMARY）+ validation-loop + checkpoint-commit + 进度状态机 + 跨会话接力。",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "ddt-aggregate": "bin/aggregate.mjs",
    "ddt-baseline": "bin/baseline.mjs",
    "ddt-report": "bin/report.mjs",
    "ddt-doctor": "bin/doctor.mjs",
    "ddt-progress": "bin/progress.mjs",
    "ddt-resume": "bin/resume.mjs",
    "ddt-tech-stack": "bin/resolve-tech-stack.mjs",
    "ddt-audit-smoke": "bin/audit-smoke.mjs",
    "ddt-sync-about": "bin/sync-about.mjs",
    "ddt-frontend-type": "bin/get-frontend-type.mjs"
  },
  "scripts": {
    "aggregate": "node bin/aggregate.mjs",
    "baseline": "node bin/baseline.mjs",
    "report": "node bin/report.mjs",
    "baseline:force": "node bin/baseline.mjs --force",
    "test": "node --test 'tests/**/*.test.mjs'",
    "test:unit": "node --test 'tests/unit/*.test.mjs'",
    "test:integration": "node --test 'tests/integration/*.test.mjs'",
    "audit:smoke": "node bin/audit-smoke.mjs",
    "about:check": "node bin/sync-about.mjs --check",
    "about:apply": "node bin/sync-about.mjs --apply"
  },
  "dependencies": {},
  "devDependencies": {},
  "keywords": ["claude-code", "delivery", "efficiency", "agent", "subagent", "workflow", "metrics"],
  "license": "MIT",
  "author": "赵文昊 <dhslegle@gmail.com>"
}
